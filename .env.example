# ================================================================
#  OWOX OKF Export — Configuration
# ================================================================
#  HOW TO USE
#  1. Copy this file and rename the copy to ".env"
#     (just remove the word "example" from the filename)
#  2. Replace the placeholder values below with your real ones
#  3. Run the export:  python3 okf-export.py --push
# ================================================================


# ----------------------------------------------------------------
#  OWOX API Key  (required)
# ----------------------------------------------------------------
#  Where to get it:
#    OWOX → Project Settings → My API Keys → Create API Key
#    Copy the full key — it starts with "owox_key_" and is shown only once.
#
OWOX_API_KEY=owox_key_paste_your_key_here

#  Export only data marts marked as "available for reporting" in OWOX.
#  Set to false to export all data marts regardless of that flag.
#  Default: true
#
SHARED_ONLY=true

#  Resource link mode.
#  When set to true, the "resource" field in each OKF document (and in viz.html)
#  links to the underlying warehouse table or view (e.g. BigQuery console URL)
#  instead of the OWOX data endpoint. Falls back to the OWOX endpoint for
#  definition types where no source table is available (e.g. SQL).
#  Default: false
#
SOURCE_LINK=false

#  Generate an interactive knowledge graph (viz.html) alongside the bundle.
#  Set to false to skip it.
#  Default: true
#
VIZ=true


# ----------------------------------------------------------------
#  GitHub  (only needed if you want to push the bundle to GitHub)
# ----------------------------------------------------------------

#  GitHub personal access token
#  Where to create one:
#    GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
#    → Generate new token
#    → Repository access: Only select repositories → pick your target repo
#    → Permissions → Repository permissions → click "+ Add permissions" → select "Contents" → set to write access
#    → Leave everything else at no access
#
GITHUB_TOKEN=paste_your_token_here

#  The GitHub repository and folder where the bundle will be pushed.
#  Format: owner/repository-name/full/path/to/folder
#
#  Examples:
#    acme-corp/data-catalog                      → pushed to repo root
#    acme-corp/data-catalog/okf                  → pushed to /okf/
#    acme-corp/data-catalog/okf/bundles/my-data  → pushed to /okf/bundles/my-data/
#
#  The folder will be created automatically if it does not exist.
#
GITHUB_REPO=your-org/your-repo-name/path/to/folder
