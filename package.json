{
  "name": "okf-export",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ui/tailwind.css -o ui/styles.css --minify",
    "predev": "npm run build:css",
    "dev": "vite",
    "predev:broker": "npm run build:css",
    "dev:broker": "OWOX_DEV_BROKER=1 vite",
    "prebuild": "npm run build:css",
    "build": "vite build",
    "test": "vitest run --poolOptions.threads.maxThreads=4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
